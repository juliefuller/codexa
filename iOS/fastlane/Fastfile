require "base64"

default_platform(:ios)

platform :ios do
  desc "Build and upload to TestFlight"
  lane :beta do

    # ── App Store Connect API authentication ──────────────────────────────────
    api_key = app_store_connect_api_key(
      key_id:                ENV["ASC_KEY_ID"],
      issuer_id:             ENV["ASC_ISSUER_ID"],
      key_content:           ENV["ASC_PRIVATE_KEY"],
      is_key_content_base64: true,
      duration:              1200,
      in_house:              false
    )

    # ── Code signing via fastlane match ──────────────────────────────────────
    # On first run, match creates the certificate and provisioning profile
    # and stores them encrypted in the MATCH_GIT_URL private repo.
    match(
      type:                    "appstore",
      api_key:                 api_key,
      git_url:                 ENV["MATCH_GIT_URL"],
      git_basic_authorization: Base64.strict_encode64(
                                 "#{ENV['MATCH_GIT_USER']}:#{ENV['MATCH_GIT_TOKEN']}"
                               ),
      app_identifier:          ENV["BUNDLE_ID"],
      password:                ENV["MATCH_PASSWORD"],
      readonly:                false
    )

    # ── Build ─────────────────────────────────────────────────────────────────
    build_app(
      workspace:        "ios/App/App.xcworkspace",
      scheme:           "App",
      export_method:    "app-store",
      clean:            true,
      output_directory: "build",
      output_name:      "Codexa.ipa",
      export_options: {
        provisioningProfiles: {
          ENV["BUNDLE_ID"] => "match AppStore #{ENV['BUNDLE_ID']}"
        }
      }
    )

    # ── Upload to TestFlight ──────────────────────────────────────────────────
    upload_to_testflight(
      api_key:                           api_key,
      ipa:                               "build/Codexa.ipa",
      skip_waiting_for_build_processing: true,
      changelog:                         "Automated build from GitHub Actions"
    )
  end
end
